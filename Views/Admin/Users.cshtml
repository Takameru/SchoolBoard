@model List<SchoolBoard.Models.ApplicationUser>
@{
    ViewData["Title"] = "Пользователи";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}
<div class="container my-5">
    <h2 class="mb-4" style="color: var(--orange);">ПОЛЬЗОВАТЕЛИ</h2>
    <table class="table table-bordered">
        <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Роли</th>
                <th>Право заявок</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var roles = userRoles != null && userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : new List<string>();
                <tr>
                    <td>@user.Email</td>
                    <td>@string.Join(", ", roles)</td>
                    <td>@(user.CanApply ? "Да" : "Нет")</td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>