@model List<SchoolBoard.Models.Student>
@{
    ViewData["Title"] = "Модерация учеников";
}
<div class="container my-5">
    <h2 class="mb-4" style="color: var(--orange);">УЧЕНИКИ НА РАССМОТРЕНИИ</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }
    @if (!Model.Any())
    {
        <div class="alert alert-info">Нет учеников, ожидающих одобрения.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ФИО</th>
                        <th>Класс</th>
                        <th>Категории</th>
                        <th>Дата добавления</th>
                        <th style="width: 200px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>@student.LastName @student.FirstName @student.MiddleName</td>
                            <td>@student.Class</td>
                            <td>
                                @foreach (var sc in student.StudentCategories)
                                {
                                    <span class="badge me-1" style="background-color: @(sc.Category.Color ?? "#e67e22");">@sc.Category.Name</span>
                                }
                            </td>
                            <td>@student.CreatedDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                <form asp-action="ApproveStudent" asp-route-id="@student.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success">ПРИНЯТЬ</button>
                                </form>
                                <form asp-action="RejectStudent" asp-route-id="@student.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить ученика @student.LastName @student.FirstName?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">ОТКЛОНИТЬ</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>