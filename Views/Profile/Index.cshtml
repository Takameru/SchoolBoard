@{
    ViewData["Title"] = "Мой профиль";
    var student = ViewBag.LinkedStudent as SchoolBoard.Models.Student;
    var canApply = ViewBag.CanApply as bool? ?? false;
}
<div class="container my-5">
    <h2 class="mb-4" style="color: var(--orange);">ПРОФИЛЬ</h2>

    <div class="row">
        <div class="col-lg-6">
            <!-- Личная информация -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Личная информация</h5>
                    <p><strong>Email:</strong> @User.Identity?.Name</p>
                    <p>
                        <strong>Роли:</strong>
                        @if (User.IsInRole("Admin")) { <span class="badge bg-danger">Администратор</span> }
                        @if (User.IsInRole("Moderator")) { <span class="badge bg-warning text-dark">Модератор</span> }
                        @if (User.IsInRole("Student")) { <span class="badge bg-primary">Ученик</span> }
                    </p>
                </div>
            </div>

            <!-- Блок действий ученика -->
            @if (User.IsInRole("Student"))
            {
                if (student != null)
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <h5 class="card-title">Моя карточка</h5>
                            <p><strong>Имя:</strong> @student.LastName @student.FirstName @student.MiddleName</p>
                            <p><strong>Класс:</strong> @student.Class</p>
                            <p><strong>Статус:</strong> @(student.Status == StudentStatus.Active ? "Активна" : "На модерации")</p>
                            <a asp-controller="Students" asp-action="EditMyCard" class="btn btn-outline-primary">
                                <i class="fa-solid fa-pen-to-square me-1"></i> Редактировать карточку
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-body text-center">
                            @if (canApply)
                            {
                                <p class="text-muted">У вас ещё нет карточки.</p>
                                <a asp-controller="Students" asp-action="CreateMyCard" class="btn btn-primary">
                                    <i class="fa-solid fa-plus me-1"></i> Подать заявку на Доску почёта
                                </a>
                            }
                            else
                            {
                                <p class="text-muted">У вас нет прав на создание заявки. Обратитесь к администратору.</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                    {
                        <text>Вы администратор. Для создания карточек используйте Админку.</text>
                        <a class="ms-2 btn btn-outline-primary" asp-controller="Admin" asp-action="AddStudent">Перейти в админку</a>
                    }
                    else
                    {
                        <text>Вы не можете создавать карточки учеников.</text>
                    }
                </div>
            }
        </div>

        <div class="col-lg-6">
            <!-- Безопасность -->
            <div class="card shadow-sm bg-dark text-white">
                <div class="card-header">
                    <h5 class="mb-0" style="color: white;">Безопасность</h5>
                </div>
                <div class="card-body">
                    <p style="color: white;">Управление учётной записью</p>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light">
                            <i class="fa-solid fa-right-from-bracket me-1"></i> Выйти
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>